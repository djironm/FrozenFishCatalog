@model List<FrozenFishCatalog.Models.ProductWeight>

<div class="admin-page-header">
    <h2><i class="bi bi-boxes me-2"></i>Inventario</h2>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-danger">
            <i class="bi bi-exclamation-triangle me-1"></i>Bajo stock: @Model.Count(w => w.StockQuantity < 10)
        </span>
        <span class="badge bg-warning text-dark">
            Medio: @Model.Count(w => w.StockQuantity >= 10 && w.StockQuantity < 30)
        </span>
        <span class="badge bg-success">
            OK: @Model.Count(w => w.StockQuantity >= 30)
        </span>
    </div>
</div>

<div class="admin-card">
    <div class="card-body">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Categoría</th>
                    <th>Peso</th>
                    <th>Precio</th>
                    <th>Stock actual</th>
                    <th>Actualizar stock</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in Model)
                {
                    var stockClass = w.StockQuantity < 10 ? "stock-low" : w.StockQuantity < 30 ? "stock-medium" : "stock-ok";
                    <tr>
                        <td><strong>@w.Product?.Name</strong></td>
                        <td><span class="badge bg-light text-dark border">@w.Product?.Category?.Name</span></td>
                        <td>@w.WeightKg kg</td>
                        <td>$@w.Price.ToString("N2")</td>
                        <td>
                            <span class="@stockClass">
                                <i class="bi @(w.StockQuantity < 10 ? "bi-exclamation-circle" : w.StockQuantity < 30 ? "bi-dash-circle" : "bi-check-circle") me-1"></i>
                                @w.StockQuantity uds.
                            </span>
                        </td>
                        <td>
                            <form asp-area="Admin" asp-controller="Inventory" asp-action="UpdateStock"
                                  asp-route-id="@w.Id" method="post" class="stock-edit-form">
                                <input type="number" name="stockQuantity" value="@w.StockQuantity"
                                       min="0" step="1" required>
                                <button type="submit" class="btn btn-sm btn-outline-primary btn-action">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
