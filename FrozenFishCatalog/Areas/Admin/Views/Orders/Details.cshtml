@model FrozenFishCatalog.Models.Order
@using FrozenFishCatalog.Models

<div class="admin-page-header">
    <h2><i class="bi bi-receipt me-2"></i>Pedido #@Model.Id</h2>
    <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row g-4">
    <!-- Order items -->
    <div class="col-lg-8">
        <div class="admin-card mb-4">
            <div class="card-header">
                <h5>Productos del Pedido</h5>
                <span class="status-badge status-@Model.Status">@Model.Status</span>
            </div>
            <div class="card-body">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Peso</th>
                            <th>Precio unit.</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td><strong>@item.ProductWeight?.Product?.Name</strong></td>
                                <td>@item.ProductWeight?.WeightKg kg</td>
                                <td>$@item.UnitPrice.ToString("N2")</td>
                                <td>@item.Quantity</td>
                                <td><strong>$@((item.UnitPrice * item.Quantity).ToString("N2"))</strong></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="text-end fw-bold">Total</td>
                            <td><strong class="text-danger">$@Model.TotalAmount.ToString("N2")</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Update status -->
        <div class="admin-card">
            <div class="card-header"><h5>Actualizar Estado</h5></div>
            <div class="card-body p-4">
                <form asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus"
                      asp-route-id="@Model.Id" method="post" class="d-flex gap-3 align-items-end admin-form">
                    <div class="flex-grow-1">
                        <label class="form-label">Estado del pedido</label>
                        <select name="status" class="form-select">
                            @foreach (OrderStatus s in ViewBag.StatusValues)
                            {
                                <option value="@s" selected="@(Model.Status == s)">@s</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-admin-primary">
                        <i class="bi bi-arrow-repeat me-1"></i>Actualizar
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Sidebar info -->
    <div class="col-lg-4">
        <div class="admin-card mb-3">
            <div class="card-header"><h5>Cliente</h5></div>
            <div class="card-body p-4">
                <p class="mb-1"><i class="bi bi-person me-2 text-muted"></i>
                    @Model.User?.FirstName @Model.User?.LastName</p>
                <p class="mb-0"><i class="bi bi-envelope me-2 text-muted"></i>
                    @Model.User?.Email</p>
            </div>
        </div>

        <div class="admin-card mb-3">
            <div class="card-header"><h5>Dirección de Envío</h5></div>
            <div class="card-body p-4">
                <p class="mb-1">@Model.ShippingAddress</p>
                <p class="mb-1">@Model.City, @Model.PostalCode</p>
                <p class="mb-0">@Model.Country</p>
            </div>
        </div>

        <div class="admin-card">
            <div class="card-header"><h5>Pago</h5></div>
            <div class="card-body p-4">
                <p class="mb-1"><small class="text-muted">Fecha</small><br>
                    @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                @if (!string.IsNullOrEmpty(Model.PaymentTransactionId))
                {
                    <p class="mb-0"><small class="text-muted">Transaction ID</small><br>
                        <code>@Model.PaymentTransactionId</code></p>
                }
            </div>
        </div>
    </div>
</div>
