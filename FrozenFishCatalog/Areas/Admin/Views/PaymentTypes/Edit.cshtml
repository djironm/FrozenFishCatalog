@model FrozenFishCatalog.Models.PaymentType

<div class="admin-page-header">
    <h2><i class="bi bi-pencil-square me-2"></i>Editar Método de Pago</h2>
    <a asp-area="Admin" asp-controller="PaymentTypes" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="admin-card">
            <div class="card-header"><h5>Datos del Método de Pago</h5></div>
            <div class="card-body p-4">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="admin-form">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre</label>
                        <input asp-for="Name" class="form-control">
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Descripción</label>
                        <input asp-for="Description" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label asp-for="Icon" class="form-label">Icono (Bootstrap Icons)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi @Model.Icon"></i></span>
                            <input asp-for="Icon" class="form-control">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DisplayOrder" class="form-label">Orden de visualización</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" min="0">
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input">
                        <label asp-for="IsActive" class="form-check-label">Activo</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-admin-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar Cambios
                        </button>
                        <a asp-area="Admin" asp-controller="PaymentTypes" asp-action="Index"
                           class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
