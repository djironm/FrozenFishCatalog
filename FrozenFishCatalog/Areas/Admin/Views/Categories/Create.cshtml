@model FrozenFishCatalog.Models.Category

<div class="admin-page-header">
    <h2><i class="bi bi-plus-circle me-2"></i>Nueva Categoría</h2>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="card-header"><h5>Datos de la Categoría</h5></div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" class="admin-form">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre</label>
                        <input asp-for="Name" class="form-control" placeholder="Ej: Pescado Blanco">
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Descripción</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ImageUrl" class="form-label">URL de Imagen</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="/images/categories/white-fish.jpg">
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-admin-primary">
                            <i class="bi bi-check-lg me-1"></i>Crear Categoría
                        </button>
                        <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
                           class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
