@model List<FrozenFishCatalog.Models.Category>

<div class="admin-page-header">
    <h2><i class="bi bi-tags me-2"></i>Categorías</h2>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-admin-primary">
        <i class="bi bi-plus-lg me-1"></i>Nueva Categoría
    </a>
</div>

<div class="admin-card">
    <div class="card-body">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>URL Imagen</th>
                    <th>Productos</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td><strong>@cat.Name</strong></td>
                        <td class="text-muted" style="max-width:280px;">
                            <span class="d-inline-block text-truncate" style="max-width:260px;" title="@cat.Description">@cat.Description</span>
                        </td>
                        <td class="text-muted" style="max-width:180px;">
                            <small class="d-inline-block text-truncate" style="max-width:160px;">@cat.ImageUrl</small>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@cat.Products.Count</span>
                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@cat.Id"
                               class="btn btn-sm btn-outline-primary btn-action me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@cat.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar la categoría «@cat.Name»?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger btn-action"
                                        @(cat.Products.Any() ? "disabled title=Tiene productos asignados" : "")>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
