@model List<FrozenFishCatalog.Models.Product>
@{
    ViewData["Title"] = "Productos";
    var categories = ViewBag.Categories as List<FrozenFishCatalog.Models.Category>;
    var currentCategory = ViewBag.CurrentCategory as FrozenFishCatalog.Models.Category;
}

<div class="page-header">
    <div class="container">
        <h1>@(currentCategory?.Name ?? "Todos los Productos")</h1>
    </div>
</div>

<div class="container py-4">
    <!-- Pestañas de Categorías -->
    <div class="category-tabs">
        <a asp-action="Index" class="category-tab @(currentCategory == null ? "active" : "")">Todos</a>
        @if (categories != null)
        {
            @foreach (var category in categories)
            {
                <a asp-action="Index" asp-route-categoryId="@category.Id"
                   class="category-tab @(currentCategory?.Id == category.Id ? "active" : "")">
                    @category.Name
                </a>
            }
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox d-block"></i>
            <h3>No se encontraron productos</h3>
            <p>Intenta seleccionar otra categoría.</p>
        </div>
    }
    else
    {
        <!-- Grilla de Productos -->
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model)
            {
                var minWeight = product.Weights.OrderBy(w => w.Price).FirstOrDefault();

                <div class="col">
                    <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                        <div class="product-card">
                            <div class="product-image">
                                <div class="placeholder-icon">
                                    <i class="bi bi-water"></i>
                                </div>
                                <div class="product-badge">Premium</div>
                            </div>
                            <div class="product-info">
                                <div class="product-name">@product.Name</div>
                                <div class="product-description">@product.Description.Substring(0, Math.Min(60, product.Description.Length))...</div>
                                <div class="product-price">
                                    <span class="price-current">$@(minWeight?.Price.ToString("N0") ?? "0")</span>
                                    <span class="price-unit">/ kg</span>
                                </div>
                                <span class="btn-more-info">Más Info</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        <div class="text-center mt-4 text-muted">
            <p>Mostrando @Model.Count producto(s)</p>
        </div>
    }
</div>
