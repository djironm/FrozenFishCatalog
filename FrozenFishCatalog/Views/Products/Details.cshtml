@model FrozenFishCatalog.ViewModels.ProductDetailsViewModel
@{
    ViewData["Title"] = Model.Product.Name;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a></li>
            <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index" class="text-decoration-none">Productos</a></li>
            <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index" asp-route-categoryId="@Model.Product.CategoryId" class="text-decoration-none">@Model.Product.Category.Name</a></li>
            <li class="breadcrumb-item active">@Model.Product.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-5">
            <div class="product-detail-image mb-4">
                <i class="bi bi-water"></i>
                <div class="product-badge" style="position: absolute; top: 20px; left: 20px;">Premium</div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="product-detail-info">
                <span class="category-badge">@Model.Product.Category.Name</span>
                <h1>@Model.Product.Name</h1>
                <p class="text-muted mb-4">@Model.Product.Description</p>

                <form asp-controller="Cart" asp-action="Add" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Seleccionar Peso</label>
                        <div class="row g-3">
                            @foreach (var weight in Model.Product.Weights.OrderBy(w => w.WeightKg))
                            {
                                <div class="col-md-4">
                                    <input type="radio" class="btn-check" name="productWeightId"
                                           id="weight-@weight.Id" value="@weight.Id"
                                           @(weight.Id == Model.SelectedWeightId ? "checked" : "")>
                                    <label class="btn btn-outline-secondary w-100 py-3 text-start" for="weight-@weight.Id" style="border-radius: 8px;">
                                        <div class="fw-bold">@weight.WeightKg kg</div>
                                        <div class="fw-bold" style="color: var(--primary-red);">$@weight.Price.ToString("F2")</div>
                                        <small class="text-muted">@weight.StockQuantity en stock</small>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Cantidad</label>
                        <div class="input-group" style="width: 150px;">
                            <button type="button" class="btn btn-outline-secondary" onclick="changeQty(-1)">
                                <i class="bi bi-dash"></i>
                            </button>
                            <input type="number" name="quantity" id="quantity" class="form-control text-center" value="1" min="1" max="99">
                            <button type="button" class="btn btn-outline-secondary" onclick="changeQty(1)">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary-red btn-lg px-5">
                            <i class="bi bi-cart-plus me-2"></i>AGREGAR AL CARRO
                        </button>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            Seguir Comprando
                        </a>
                    </div>
                </form>

                <div class="row mt-5 pt-4 border-top">
                    <div class="col-4 text-center">
                        <i class="bi bi-truck fs-3" style="color: var(--primary-red);"></i>
                        <p class="small mb-0 mt-2">Envío Gratis</p>
                    </div>
                    <div class="col-4 text-center">
                        <i class="bi bi-snow fs-3" style="color: var(--primary-red);"></i>
                        <p class="small mb-0 mt-2">Congelado Fresco</p>
                    </div>
                    <div class="col-4 text-center">
                        <i class="bi bi-award fs-3" style="color: var(--primary-red);"></i>
                        <p class="small mb-0 mt-2">Calidad Premium</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function changeQty(delta) {
        const input = document.getElementById('quantity');
        let val = parseInt(input.value) + delta;
        if (val >= 1 && val <= 99) {
            input.value = val;
        }
    }

    document.querySelectorAll('.btn-check').forEach(radio => {
        radio.addEventListener('change', function() {
            document.querySelectorAll('.btn-check + label').forEach(label => {
                label.classList.remove('btn-secondary');
                label.classList.add('btn-outline-secondary');
            });
            if (this.checked) {
                this.nextElementSibling.classList.remove('btn-outline-secondary');
                this.nextElementSibling.classList.add('btn-secondary');
            }
        });
    });
</script>
}
