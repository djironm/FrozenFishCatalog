@model FrozenFishCatalog.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Carro de Compras";
}

<div class="container py-4">
    <h1 class="mb-4" style="color: var(--text-dark);"><i class="bi bi-cart3 me-2"></i>Carro de Compras</h1>

    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <i class="bi bi-cart-x d-block"></i>
            <h3>Tu carro está vacío</h3>
            <p>Parece que aún no has agregado productos.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary-red btn-lg mt-3">
                <i class="bi bi-grid me-2"></i>VER PRODUCTOS
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header py-3" style="background-color: var(--text-dark); color: white;">
                        <span class="fw-bold">@Model.TotalItems artículo(s) en tu carro</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 50%">Producto</th>
                                    <th class="text-center">Precio</th>
                                    <th class="text-center">Cantidad</th>
                                    <th class="text-end">Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-light rounded d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px;">
                                                    <i class="bi bi-water text-secondary"></i>
                                                </div>
                                                <div>
                                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none fw-bold" style="color: var(--text-dark);">
                                                        @item.ProductName
                                                    </a>
                                                    <div class="small" style="color: var(--primary-red);">@item.WeightKg kg</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center align-middle">$@item.UnitPrice.ToString("F2")</td>
                                        <td class="text-center align-middle">
                                            <form asp-action="Update" method="post" class="d-inline">
                                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                                <div class="input-group input-group-sm justify-content-center" style="width: 120px;">
                                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="btn btn-outline-secondary">-</button>
                                                    <span class="form-control text-center bg-white">@item.Quantity</span>
                                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="btn btn-outline-secondary">+</button>
                                                </div>
                                            </form>
                                        </td>
                                        <td class="text-end align-middle fw-bold" style="color: var(--text-dark);">$@item.Subtotal.ToString("F2")</td>
                                        <td class="align-middle">
                                            <form asp-action="Remove" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="order-summary p-4">
                    <h5 class="fw-bold mb-4">Resumen del Pedido</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>$@Model.TotalPrice.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Envío</span>
                        <span style="color: var(--primary-red);">GRATIS</span>
                    </div>
                    <hr style="border-color: rgba(255,255,255,0.2);" />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">Total</span>
                        <span class="fw-bold fs-5" style="color: var(--primary-red);">$@Model.TotalPrice.ToString("F2")</span>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-lg">
                            <i class="bi bi-credit-card me-2"></i>IR A PAGAR
                        </a>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mt-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-shield-check fs-3 me-3" style="color: var(--primary-red);"></i>
                            <div>
                                <div class="fw-bold">Compra Segura</div>
                                <small class="text-muted">Tus datos están protegidos</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
