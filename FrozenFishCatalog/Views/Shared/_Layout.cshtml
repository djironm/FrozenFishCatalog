@using Microsoft.AspNetCore.Identity
@using FrozenFishCatalog.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pesca Cisne</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Barra Superior -->
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <a href="#"><i class="bi bi-telephone me-1"></i> +56 9 1234 5678</a>
                <a href="#"><i class="bi bi-envelope me-1"></i> contacto@pescacisne.cl</a>
            </div>
            <div class="d-flex align-items-center">
                <a href="#">Español</a>
                <a href="#">English</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-controller="Cart" asp-action="Index" class="ms-3">
                        <i class="bi bi-cart3"></i> Carrito
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Navbar Principal -->
    <nav class="navbar navbar-expand-lg navbar-main">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-pesca">Pesca</span><span class="brand-cisne">Cisne</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Nuestra Empresa</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Productos
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">Todos los Productos</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-categoryId="1">Pescado Blanco</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-categoryId="2">Pescado Azul</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-categoryId="3">Mariscos</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-categoryId="4">Pescado Exótico</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Contacto</a>
                    </li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a asp-controller="Cart" asp-action="Index" class="nav-link cart-icon">
                                <i class="bi bi-cart3 fs-5"></i>
                                <span class="cart-badge">0</span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>
                                <span class="d-none d-md-inline">@User.Identity?.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                            <i class="bi bi-gear me-2"></i>Panel Admin
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Login" class="nav-link">
                                <i class="bi bi-person me-1"></i> Acceso
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- Pie de Página -->
    <footer class="footer">
        <div class="container footer-content">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <h5>Menú</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li><a href="#">Nuestra Empresa</a></li>
                        <li><a href="#">Frigorífico</a></li>
                        <li><a asp-controller="Products" asp-action="Index">Productos</a></li>
                        <li><a href="#">Contacto</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <h5>Productos</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="1">Pescado Blanco</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="2">Pescado Azul</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="3">Mariscos</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="4">Pescado Exótico</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h5>Contacto</h5>
                    <div class="footer-contact">
                        <p><i class="bi bi-geo-alt"></i> Puerto Cisnes, Región de Aysén, Chile</p>
                        <p><i class="bi bi-telephone"></i> +56 9 1234 5678</p>
                        <p><i class="bi bi-envelope"></i> contacto@pescacisne.cl</p>
                    </div>
                    <div class="social-icons">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                <p>&copy; @DateTime.Now.Year Pesca Cisne. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
